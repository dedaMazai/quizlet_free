{
  "name": "english-flashcards-app",
  "version": "1.0.0",
  "description": "English vocabulary learning app — flashcards, decks and study modes (Quizlet-style prototype). React 19 / TypeScript / Webpack 5.",
  "main": "index.js",
  "private": true,
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "private"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "prestart": "npm run gen:scss-types",
    "start": "concurrently -k -n webpack,scss-types -c blue,yellow \"npm:start:webpack\" \"npm:gen:scss-types:watch\"",
    "start:webpack": "cross-env NODE_ENV=development TS_NODE_PROJECT=tsconfig.json node -r ts-node/register ./node_modules/webpack/bin/webpack.js serve",
    "serve": "serve build -p 3001 -s",
    "prebuild": "npm run gen:scss-types",
    "build": "cross-env NODE_ENV=production TS_NODE_PROJECT=tsconfig.json node -r ts-node/register ./node_modules/webpack/bin/webpack.js",
    "prebuild:dev": "npm run gen:scss-types",
    "build:dev": "cross-env NODE_ENV=development TS_NODE_PROJECT=tsconfig.json node -r ts-node/register ./node_modules/webpack/bin/webpack.js",
    "prebuild:analyze": "npm run gen:scss-types",
    "build:analyze": "cross-env NODE_ENV=production ANALYZE=true TS_NODE_PROJECT=tsconfig.json node -r ts-node/register ./node_modules/webpack/bin/webpack.js",
    "clean": "rm -rf build",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "lint:scss": "stylelint \"**/*.scss\"",
    "lint:scss:fix": "stylelint \"**/*.scss\" --fix",
    "gen:scss-types": "typed-scss-modules \"src/**/*.module.scss\" -e default -n none -u --logLevel error",
    "gen:scss-types:watch": "typed-scss-modules \"src/**/*.module.scss\" -e default -n none --watch --logLevel error",
    "pretypecheck": "npm run gen:scss-types",
    "typecheck": "tsc --noEmit",
    "test": "jest --config ./config/jest/jest.config.ts"
  },
  "keywords": [
    "english",
    "vocabulary",
    "flashcards",
    "learning",
    "quiz",
    "spaced-repetition",
    "react"
  ],
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/plugin-transform-runtime": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@eslint/js": "^9.18.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.17",
    "@svgr/webpack": "^8.1.0",
    "@types/circular-dependency-plugin": "^5.0.8",
    "@types/compression-webpack-plugin": "^9.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/webpack": "^5.28.5",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "@types/zxcvbn": "^4.4.5",
    "babel-loader": "^10.0.0",
    "babel-plugin-i18next-extract": "^1.1.0",
    "circular-dependency-plugin": "^5.2.2",
    "compression-webpack-plugin": "^12.0.0",
    "concurrently": "^10.0.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-import-x": "^4.6.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "globals": "^15.14.0",
    "html-webpack-plugin": "^5.6.4",
    "mini-css-extract-plugin": "^2.9.4",
    "prettier": "3.6.2",
    "react-refresh": "^0.18.0",
    "sass": "^1.93.2",
    "sass-loader": "^16.0.5",
    "serve": "^14.2.1",
    "style-loader": "^4.0.0",
    "stylelint": "^16.25.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "terser-webpack-plugin": "^5.3.14",
    "ts-node": "^10.9.2",
    "typed-scss-modules": "^8.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.21.0",
    "webpack": "^5.102.1",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@react-spring/web": "^10.0.3",
    "@reduxjs/toolkit": "^2.11.0",
    "@rtk-query/codegen-openapi": "^2.1.0",
    "@sentry/react": "^10.11.0",
    "@sentry/webpack-plugin": "^5.3.0",
    "@supabase/supabase-js": "^2.108.2",
    "@use-gesture/react": "^10.3.1",
    "antd": "^6.1.3",
    "antd-img-crop": "^4.27.0",
    "async-mutex": "^0.5.0",
    "chart.js": "^4.5.0",
    "chartjs-plugin-datalabels": "^2.2.0",
    "core-js": "^3.47.0",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.13",
    "docx": "^9.5.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "i18next": "^25.0.1",
    "i18next-browser-languagedetector": "^8.0.4",
    "i18next-http-backend": "^3.0.2",
    "i18next-intervalplural-postprocessor": "^3.0.0",
    "react": "^19.2.5",
    "react-chartjs-2": "^5.3.0",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19.2.5",
    "react-i18next": "^15.4.1",
    "react-redux": "^9.2.0",
    "react-router": "^7.11.0",
    "react-router-dom": "^7.11.0",
    "react-virtuoso": "^4.18.1",
    "socket.io-client": "^4.8.3",
    "typescript-cookie": "^1.0.6",
    "zxcvbn": "^4.4.2"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
